# SDMX endpoint and request identity
SDMX_BASE_URL=https://sdmx.data.unicef.org/ws/public/sdmxapi/rest
SDMX_USER_AGENT=sdmx-mcp/0.1

# Policy and retrieval defaults
SDMX_QUERY_DIMENSION_POLICY_FILE=query_dimension_policy.json
SDMX_DEFAULT_LAST_N_OBSERVATIONS=true

# Optional scoping
SDMX_AGENCY_ALLOWLIST=UNICEF,UNPD
