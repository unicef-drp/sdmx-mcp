# Required: SDMX registry base URL
SDMX_BASE_URL=https://example.org/ws/public/sdmxapi/rest

# Optional identity
SDMX_MCP_NAME=sdmx-mcp
SDMX_USER_AGENT=sdmx-mcp/0.1

# Optional: custom prefix mapping CSV path
# Relative paths resolve from the repository root when exported from your shell.
SDMX_THEME_PREFIX_CSV=theme_prefixes_domain.csv

# Optional scoping (recommended for mixed prod/draft registries)
SDMX_EXCLUDE_DRAFT=true
SDMX_AGENCY_ALLOWLIST=UNICEF
# SDMX_DATAFLOW_ID_ALLOW_PREFIXES=PROD_,CORE_
# SDMX_DATAFLOW_ID_DENY_PREFIXES=DRAFT_,TMP_
# SDMX_DATAFLOW_ID_ALLOW_REGEX=^(PROD_|CORE_)
# SDMX_DATAFLOW_ID_DENY_REGEX=(DRAFT|TMP)

# Optional: when true, explicit flowRef calls outside scope are rejected.
# Default auto-enables when any scope filter is set.
# SDMX_ENFORCE_SCOPE=true
